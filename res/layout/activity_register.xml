<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header band -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient_red"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your details to register"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="-24dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#111827"
            app:cardCornerRadius="28dp"
            app:cardElevation="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Selfie section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR PHOTO"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="12dp"/>

                <ImageView
                    android:id="@+id/selfieImageView"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_avatar_circle_cyan"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="Selfie preview"/>

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_avatar_circle_cyan"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerInside"
                    android:padding="24dp"
                    android:layout_marginBottom="10dp"
                    android:contentDescription="Selfie placeholder"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/takeSelfieButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_gravity="center_horizontal"
                    android:text="📷  Take Selfie"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#FF3B5C"
                    app:cornerRadius="12dp"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/selfieStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No selfie taken yet"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E293B"
                    android:layout_marginBottom="20dp"/>

                <!-- Personal details label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL DETAILS"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="16dp"/>

                <!-- Full Name -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/RC.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Name *"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/nameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:singleLine="true"
                        android:textColor="#F1F5F9"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mobile -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/RC.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile Number *"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/mobileEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:singleLine="true"
                        android:textColor="#F1F5F9"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/RC.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Address *"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textColor="#F1F5F9"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Emergency message -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/RC.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Emergency Message *"
                    android:layout_marginBottom="20dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emergencyEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:lines="2"
                        android:textColor="#F1F5F9"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E293B"
                    android:layout_marginBottom="20dp"/>

                <!-- Identity verification label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDENTITY VERIFICATION"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="4dp"/>


                <!-- Aadhaar -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/RC.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Aadhaar Number (12 digits)"
                    app:endIconMode="password_toggle"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/aadhaarEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberPassword"
                        android:singleLine="true"
                        android:maxLength="12"
                        android:textColor="#F1F5F9"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Info box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_status_chip"
                    android:padding="12dp"
                    android:layout_marginBottom="28dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️  "
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Format validation only. Full OTP-based verification requires UIDAI AUA/ASA licensing."
                        android:textSize="11sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <!-- Register button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/registerButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:onClick="registerImplementation"
                    android:text="Create Account"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#FF3B5C"
                    app:cornerRadius="16dp"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="16dp"/>

                <ProgressBar
                    android:id="@+id/registerProgressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#FF3B5C"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>