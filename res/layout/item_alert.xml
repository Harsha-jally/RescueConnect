<?xml version="1.0" encoding="utf-8"?>
<!--
    item_alert.xml
    Alert card shown in VolunteerHomeActivity's ListView.

    IDs required by AlertAdapter:
      R.id.alertMessage    — main SOS message text
      R.id.respondersText  — "🙋 Going: Name1, Name2"
      R.id.statusText      — "✅ Resolved by: Name"
      R.id.navigateBtn     — open navigation
      R.id.imGoingBtn      — accept / already accepted
      R.id.iHelpedBtn      — mark help as done
      R.id.cantGoBtn       — ← NEW: back out after accepting
      R.id.callUserBtn     — call the SOS user directly
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="#0D1F2D"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- ── SOS message ──────────────────────────────────────────── -->
        <TextView
            android:id="@+id/alertMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SOS: Help needed!"
            android:textColor="#F1F5F9"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            android:lineSpacingMultiplier="1.3"/>

        <!-- ── Responders line (hidden when empty) ──────────────────── -->
        <TextView
            android:id="@+id/respondersText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🙋 Going: Volunteer"
            android:textColor="#4ADE80"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:visibility="gone"/>

        <!-- ── Resolved status (hidden when not resolved) ───────────── -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="✅ Resolved by: Volunteer"
            android:textColor="#86EFAC"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:visibility="gone"/>

        <!-- ── Divider ───────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#1E293B"/>

        <!-- ── Row 1: Navigate + I'm Going ──────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/navigateBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#1E3A5F"
                android:text="🗺 Navigate"
                android:textColor="#93C5FD"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/imGoingBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#14532D"
                android:text="🙋 I'm Going"
                android:textColor="#4ADE80"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

        </LinearLayout>

        <!-- ── Row 2: I Helped + Call User (shown only when going) ──── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/iHelpedBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#0F3460"
                android:text="✅ I Helped"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/callUserBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#1C3335"
                android:text="📞 Call User"
                android:textColor="#34D399"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ── Row 3: I Can't Go (shown only when committed, full width) -->
        <Button
            android:id="@+id/cantGoBtn"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:backgroundTint="#3B0000"
            android:text="😔 I Can't Go"
            android:textColor="#FCA5A5"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>