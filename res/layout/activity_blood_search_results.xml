<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · activity_blood_search_results.xml
  Full-screen results page launched after pincode search
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:orientation="vertical">

    <!-- ── Header with back button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A0000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="16dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FF5252"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩸 Search Results"
                android:textColor="#FF5252"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"/>

            <!-- Shows "B+ · 560001" -->
            <TextView
                android:id="@+id/tvSearchSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CC9E9E9E"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Results header bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RESULTS"
            android:textColor="#FF5252"
            android:textSize="10sp"
            android:letterSpacing="0.14"
            android:textAllCaps="true"
            android:fontFamily="@font/poppins_medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a card to call"
            android:textColor="#4A5568"
            android:textSize="10sp"
            android:fontFamily="@font/poppins_regular"/>

    </LinearLayout>

    <!-- ── Results list ── -->
    <ListView
        android:id="@+id/listResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="24dp"/>

</LinearLayout>