<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- ── Header ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:tint="#94A3B8"
                android:contentDescription="Back"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safety Settings"
                    android:textColor="#F1F5F9"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap an option to select, then save"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SECTION 1 — Auto-SOS Cancel Window                         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡  AUTO-SOS CANCEL WINDOW"
            android:textColor="#60A5FA"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="After a crash / drop / scream is detected, how long do you have to tap CANCEL before SOS fires automatically?"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0D1F2D"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <RadioGroup
                android:id="@+id/rgCancelWindow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <RadioButton android:id="@+id/rCancelW_30s"
                    style="@style/SettingsRadioBtn"
                    android:text="30 seconds" android:tag="30000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rCancelW_1m"
                    style="@style/SettingsRadioBtn"
                    android:text="1 minute" android:tag="60000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rCancelW_2m"
                    style="@style/SettingsRadioBtn"
                    android:text="2 minutes" android:tag="120000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rCancelW_3m"
                    style="@style/SettingsRadioBtn"
                    android:text="3 minutes" android:tag="180000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rCancelW_5m"
                    style="@style/SettingsRadioBtn"
                    android:text="5 minutes" android:tag="300000"/>

            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SECTION 2 — Monitor Me Check-in Interval                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁️  MONITOR ME — CHECK-IN INTERVAL"
            android:textColor="#60A5FA"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How often should the &quot;Are you safe?&quot; notification appear while Monitor Me is running?"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0D1F2D"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <RadioGroup
                android:id="@+id/rgPingInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <RadioButton android:id="@+id/rPing_30s"
                    style="@style/SettingsRadioBtn"
                    android:text="30 seconds" android:tag="30000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rPing_1m"
                    style="@style/SettingsRadioBtn"
                    android:text="1 minute" android:tag="60000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rPing_2m"
                    style="@style/SettingsRadioBtn"
                    android:text="2 minutes" android:tag="120000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rPing_3m"
                    style="@style/SettingsRadioBtn"
                    android:text="3 minutes" android:tag="180000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rPing_5m"
                    style="@style/SettingsRadioBtn"
                    android:text="5 minutes" android:tag="300000"/>

            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SECTION 3 — Monitor Me Response Timeout                    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️  MONITOR ME — RESPONSE TIMEOUT"
            android:textColor="#60A5FA"
            android:textSize="11sp"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="If you don't respond to a check-in notification, SOS fires automatically after this long."
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#0D1F2D"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <RadioGroup
                android:id="@+id/rgResponseTimeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <RadioButton android:id="@+id/rTimeout_30s"
                    style="@style/SettingsRadioBtn"
                    android:text="30 seconds" android:tag="30000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rTimeout_1m"
                    style="@style/SettingsRadioBtn"
                    android:text="1 minute" android:tag="60000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rTimeout_2m"
                    style="@style/SettingsRadioBtn"
                    android:text="2 minutes" android:tag="120000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rTimeout_3m"
                    style="@style/SettingsRadioBtn"
                    android:text="3 minutes" android:tag="180000"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B"/>

                <RadioButton android:id="@+id/rTimeout_5m"
                    style="@style/SettingsRadioBtn"
                    android:text="5 minutes" android:tag="300000"/>

            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <!-- ── Save Button ───────────────────────────────────────────── -->
        <Button
            android:id="@+id/saveSettingsBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1D4ED8"
            android:text="✅  Save Settings"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"
            android:elevation="6dp"/>

    </LinearLayout>

</ScrollView>