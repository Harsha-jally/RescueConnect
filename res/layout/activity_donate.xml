<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · activity_donate.xml
  Shows verified fund campaigns with progress bar + donate button
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:orientation="vertical">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient_gold"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️ Donate to Patients"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verified campaigns — every rupee counts"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- ── Empty state ── -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💙"
            android:textSize="60sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Campaigns Yet"
            android:textColor="#F1F5F9"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verified fund requests will appear here.\nCheck back soon."
            android:textColor="#64748B"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <!-- ── Loading spinner ── -->
    <LinearLayout
        android:id="@+id/loadingState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#F59E0B"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading campaigns…"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- ── Campaigns list ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCampaigns"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"/>

</LinearLayout>