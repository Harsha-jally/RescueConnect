<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · item_result_card.xml
  Modern card layout for blood donor / blood bank / map rows
  Place in:  res/layout/item_result_card.xml
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Left accent / icon strip -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_result_icon_circle"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvResultIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:text="🩸"/>

        </LinearLayout>

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Donor Name"/>

            <TextView
                android:id="@+id/tvResultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Blood: A+  |  Pincode: 560001"/>

            <TextView
                android:id="@+id/tvResultPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="6dp"
                android:drawablePadding="4dp"
                android:text="📞 9876543210"/>

        </LinearLayout>

        <!-- Right action chevron / call badge -->
        <TextView
            android:id="@+id/tvResultAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#FF5252"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:paddingStart="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>