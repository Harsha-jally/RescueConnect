<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · activity_admin_dashboard.xml
  Redesigned: Modern dark UI — fixed header stack, dynamic tab chips,
  polished section bar, and cleaner list area.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B14"
    android:orientation="vertical"
    tools:context=".AdminDashboardActivity">

    <!-- ══════════════════════════════════════════════
         HEADER  — title + subtitle stacked vertically
         with a right-side shield accent icon
    ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient_green"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="52dp"
        android:paddingEnd="20dp"
        android:paddingBottom="22dp"
        android:gravity="center_vertical">

        <!-- Left: Title + subtitle stacked -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="🛡️ Admin Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/poppins_regular"
                android:text="RescueConnect Control Panel"
                android:textColor="#ADFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Right: Pill badge "ADMIN" -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2600E676"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="#00E676"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_semibold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         TAB BAR  — wrap_content chips, consistent spacing
    ══════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1120"
        android:scrollbars="none"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/tabUsers"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_active_green"
                android:text="👤 Users"
                android:textColor="#001A0A"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tabVolunteers"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="🙌 Volunteers"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tabResponses"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="📡 Alerts"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tabContributions"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="💳 Payments"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tabFundRequests"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="💊 Fund Requests"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/tabBloodDonors"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="🩸 Blood Donors"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════
         SECTION HEADER  — title + subtitle + count pill
    ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical"
        android:background="#070B14">

        <!-- Left: Title + sub-label -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Users"
                android:textColor="#F1F5F9"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Manage and review records"
                android:textColor="#475569"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>

        <!-- Right: Count pill badge -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D2D1A"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/countText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 records"
                android:textColor="#00E676"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         DIVIDER  — subtle accent line
    ══════════════════════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A2235"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- ══════════════════════════════════════════════
         MAIN LIST  — full-height scrollable content
    ══════════════════════════════════════════════════ -->
    <ListView
        android:id="@+id/adminListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:clipToPadding="false"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:scrollbarStyle="outsideOverlay"
        android:background="#070B14" />

</LinearLayout>