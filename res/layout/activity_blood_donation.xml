<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · activity_blood_donation.xml
  Dark neon-pulse theme — matches app style
  Drawables needed:
    • bg_tab_active_red  — GradientDrawable startColor=#E53935 endColor=#B71C1C cornerRadius=20dp
    • bg_tab_inactive    — already exists
    • bg_role_btn_blood  — GradientDrawable startColor=#E53935 endColor=#B71C1C cornerRadius=20dp
-->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:orientation="vertical"
    tools:context=".BloodDonationActivity">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A0000"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🩸 Blood Donation"
            android:textColor="#FF5252"
            android:textSize="26sp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donate or find blood near you"
            android:textColor="#CC9E9E9E"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- ── Tab bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#111827"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/tabDonate"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_tab_active_red"
            android:text="❤️ I Want to Donate"
            android:textColor="#1A0000"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/tabFind"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="38dp"
            android:background="@drawable/bg_tab_inactive"
            android:text="🔍 I Need Blood"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_medium"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         PANEL: DONATE (register as donor)
    ═══════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panelDonate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#111827"
                app:cardCornerRadius="24dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DONOR REGISTRATION"
                        android:textColor="#FF5252"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="20dp"/>

                    <!-- Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etDonorName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="e.g. Rahul Kumar"
                        android:textColorHint="#4A5568"
                        android:textColor="#F1F5F9"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="16dp"/>

                    <!-- Phone Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone Number"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etDonorPhone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="10-digit mobile number"
                        android:textColorHint="#4A5568"
                        android:textColor="#F1F5F9"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:layout_marginBottom="16dp"/>

                    <!-- Blood Group -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Blood Group"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerDonorBloodGroup"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_dark"
                        android:layout_marginBottom="16dp"
                        android:paddingStart="16dp"
                        android:spinnerMode="dropdown"/>

                    <!-- Pincode -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Pincode"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etDonorPincode"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="6-digit pincode"
                        android:textColorHint="#4A5568"
                        android:textColor="#F1F5F9"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="number"
                        android:maxLength="6"
                        android:layout_marginBottom="28dp"/>

                    <Button
                        android:id="@+id/btnRegisterDonor"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_role_btn_blood"
                        android:text="❤️  Register as Blood Donor"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:stateListAnimator="@null"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info note -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your details are shared only with verified recipients in need."
                android:textColor="#4A5568"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="16dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center"/>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════
         PANEL: FIND (search donors + blood banks)
    ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelFind"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Search card — results open in BloodSearchResultsActivity -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardBackgroundColor="#111827"
            app:cardCornerRadius="20dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FIND BLOOD NEAR YOU"
                    android:textColor="#FF5252"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="16dp"/>

                <!-- Blood Group needed -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Group Needed"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerFindBloodGroup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:layout_marginBottom="14dp"
                    android:paddingStart="16dp"
                    android:spinnerMode="dropdown"/>

                <!-- Your pincode -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Pincode"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etFindPincode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="6-digit pincode"
                    android:textColorHint="#4A5568"
                    android:textColor="#F1F5F9"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="number"
                    android:maxLength="6"
                    android:layout_marginBottom="18dp"/>

                <Button
                    android:id="@+id/btnFindDonors"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_role_btn_blood"
                    android:text="🔍  Search Donors &amp; Blood Banks"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>