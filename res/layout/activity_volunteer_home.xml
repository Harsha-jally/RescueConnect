<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0A0E1A" tools:context=".VolunteerHomeActivity">
    <!--  ── Top gradient band ──  -->
    <View android:id="@+id/topBand" android:layout_width="0dp" android:layout_height="140dp" android:background="@drawable/bg_header_gradient_cyan" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <!--  ── Profile Card ──  -->
    <androidx.cardview.widget.CardView android:id="@+id/profileCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="90dp" app:cardBackgroundColor="#111827" app:cardCornerRadius="24dp" app:cardElevation="16dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
            <!--  Avatar circle  -->
            <View android:id="@+id/avatarBg" android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_avatar_circle_cyan" android:layout_alignParentStart="true" android:layout_centerVertical="true"/>
            <TextView android:id="@+id/avatarInitial" android:layout_width="56dp" android:layout_height="56dp" android:gravity="center" android:text="V" android:textColor="#00D4FF" android:textSize="22sp" android:fontFamily="@font/poppins_bold" android:layout_alignParentStart="true" android:layout_centerVertical="true"/>
            <!--  Greeting text  -->
            <TextView android:id="@+id/greetingText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@+id/avatarBg" android:layout_marginStart="14dp" android:layout_marginTop="6dp" android:text="Hi, Volunteer 👋" android:textColor="#F1F5F9" android:textSize="18sp" android:fontFamily="@font/poppins_bold"/>
            <TextView android:id="@+id/roleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@+id/greetingText" android:layout_toEndOf="@+id/avatarBg" android:layout_marginStart="14dp" android:layout_marginTop="2dp" android:text="Active Volunteer" android:textColor="#64748B" android:textSize="12sp" android:fontFamily="@font/poppins_regular"/>
            <!--  Alert badge  -->
            <androidx.cardview.widget.CardView android:id="@+id/alertBadgeCard" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" app:cardBackgroundColor="#FF3B5C" app:cardCornerRadius="20dp" app:cardElevation="4dp">
                <TextView android:id="@+id/alertCountText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="6dp" android:paddingBottom="6dp" android:text="0 Alerts" android:textColor="#fff" android:textSize="12sp" android:fontFamily="@font/poppins_semibold"/>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
    <!--  ── Earnings Accordion Card ──  -->
    <androidx.cardview.widget.CardView android:id="@+id/earningsCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="12dp" app:cardBackgroundColor="#111827" app:cardCornerRadius="16dp" app:cardElevation="8dp" app:layout_constraintTop_toBottomOf="@id/profileCard" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!--  ── Tap-to-toggle header row ──  -->
            <RelativeLayout android:id="@+id/earningsToggleRow" android:layout_width="match_parent" android:layout_height="52dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <!--  💰 label + amount  -->
                <TextView android:id="@+id/totalEarnedText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentStart="true" android:text="💰 Total Earned: ₹0" android:textColor="#00D4FF" android:textSize="15sp" android:fontFamily="@font/poppins_bold"/>
                <!--  Dropdown arrow  -->
                <TextView android:id="@+id/earningsArrow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:text="▼" android:textColor="#64748B" android:textSize="12sp" android:fontFamily="@font/poppins_regular"/>
            </RelativeLayout>
            <!--  ── Collapsible details panel (hidden by default) ──  -->
            <LinearLayout android:id="@+id/earningsExpandPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="12dp" android:visibility="gone">
                <!--  Divider  -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E293B" android:layout_marginBottom="8dp"/>
                <!--  Sub-header  -->
                <TextView android:id="@+id/earningsListHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="📋 Earnings Breakdown:" android:textColor="#94A3B8" android:textSize="12sp" android:fontFamily="@font/poppins_regular"/>
                <!--  Per-rescue breakdown list  -->
                <ListView android:id="@+id/earningsListView" android:layout_width="match_parent" android:layout_height="160dp" android:divider="#1E293B" android:dividerHeight="1dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!--  ── Section header ──  -->
    <TextView android:id="@+id/alertsHeader" android:layout_width="0dp" android:layout_height="wrap_content" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="20dp" android:paddingBottom="8dp" android:text="📡 Live Emergency Alerts" android:textColor="#F1F5F9" android:textSize="15sp" android:fontFamily="@font/poppins_semibold" app:layout_constraintTop_toBottomOf="@id/earningsCard" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <!--  ── Divider accent ──  -->
    <View android:id="@+id/accentDivider" android:layout_width="40dp" android:layout_height="3dp" android:background="@drawable/bg_divider_cyan" android:layout_marginStart="20dp" app:layout_constraintTop_toBottomOf="@id/alertsHeader" app:layout_constraintStart_toStartOf="parent"/>
    <!--  ── Alerts list ──  -->
    <ListView android:id="@+id/listView" android:layout_width="0dp" android:layout_height="0dp" android:layout_marginTop="8dp" android:divider="@null" android:dividerHeight="0dp" android:clipToPadding="false" android:paddingBottom="16dp" app:layout_constraintTop_toBottomOf="@id/accentDivider" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>