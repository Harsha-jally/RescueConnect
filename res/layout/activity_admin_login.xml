<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    tools:context=".AdminLoginActivity">

    <!-- Green glow bottom -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_glow_circle_green"
        android:alpha="0.14"
        android:translationX="80dp"
        android:translationY="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Shield icon -->
    <ImageView
        android:id="@+id/adminIcon"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:src="@drawable/ic_shield_logo"
        android:contentDescription="Admin"
        android:tint="#00E676"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/adminTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.28"/>

    <TextView
        android:id="@+id/adminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Portal"
        android:textColor="#F1F5F9"
        android:textSize="30sp"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/adminIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/adminSubtitle"/>

    <TextView
        android:id="@+id/adminSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Restricted access — authorised personnel only"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/adminTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/formCard"/>

    <!-- Form card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/formCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#111827"
        app:cardCornerRadius="28dp"
        app:cardElevation="20dp"
        app:layout_constraintTop_toBottomOf="@id/adminSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/RC.TextInputLayout.Green"
                android:hint="Admin ID"
                app:startIconDrawable="@drawable/ic_badge"
                app:startIconTint="#00E676"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adminIdEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="#F1F5F9"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/RC.TextInputLayout.Green"
                android:hint="Password"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#00E676"
                app:endIconMode="password_toggle"
                android:layout_marginBottom="28dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/adminPasswordEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#F1F5F9"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminLoginBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:onClick="adminLoginImplementation"
                android:text="Access Dashboard"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#001A0A"
                app:backgroundTint="#00E676"
                app:cornerRadius="16dp"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>