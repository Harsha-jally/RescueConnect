<?xml version="1.0" encoding="utf-8"?>
<!--
  item_admin_card.xml — Alerts, Payments, Fund Requests, Blood Donors
  Three-level hierarchy: cardTitle (bold) + cardDetails (gray) + cardStatus (colored chip)
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#111827"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left accent strip -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#00E676"
            android:minHeight="72dp"/>

        <!-- Content: title + details + status chip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Title — first line of row data -->
            <TextView
                android:id="@+id/cardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <!-- Details — middle lines -->
            <TextView
                android:id="@+id/cardDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingMultiplier="1.5"/>

            <!-- Status chip — last line (action hint or resolved state) -->
            <TextView
                android:id="@+id/cardStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Right chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#334155"
            android:textSize="26sp"
            android:paddingStart="4dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical"
            android:fontFamily="sans-serif-light"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>