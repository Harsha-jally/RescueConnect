<?xml version="1.0" encoding="utf-8"?>
<!-- activity_settings.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    tools:context=".SettingsActivity">

    <!-- Glow deco -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_circle_red"
        android:alpha="0.10"
        android:translationX="80dp"
        android:translationY="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Settings icon + title -->
    <ImageView
        android:id="@+id/settingsIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="Settings"
        android:tint="#FF3B5C"
        android:layout_marginTop="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/settingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="#F1F5F9"
        android:textSize="28sp"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/settingsIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Settings card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settingsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#111827"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:layout_constraintTop_toBottomOf="@id/settingsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contact"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/RC.TextInputLayout"
                android:hint="New emergency contact number"
                app:startIconDrawable="@drawable/ic_emergency"
                app:startIconTint="#FF3B5C"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/changeemergencyEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="#F1F5F9"
                    android:hint="@string/register_emergency"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/register"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:onClick="changeImplementation"
                android:text="Save Changes"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#FF3B5C"
                app:cornerRadius="16dp"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>