<?xml version="1.0" encoding="utf-8"?>
<!--
  item_admin_person.xml — Users & Volunteers
  Separate personName (large) + personDetails (small gray)
  No external drawables needed.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#111827"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Green left accent strip -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#00E676"
            android:minHeight="76dp"/>

        <!-- Profile photo -->
        <ImageView
            android:id="@+id/personPhoto"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="14dp"
            android:scaleType="centerCrop"
            android:background="#1E293B"
            android:src="@drawable/ic_person_placeholder"/>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="44dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:background="#1E293B"/>

        <!-- Name + Details stacked -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Name — first line, prominent -->
            <TextView
                android:id="@+id/personName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <!-- Details — remaining lines, small gray -->
            <TextView
                android:id="@+id/personDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingMultiplier="1.5"/>

        </LinearLayout>

        <!-- Right chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#334155"
            android:textSize="26sp"
            android:paddingStart="8dp"
            android:paddingEnd="14dp"
            android:fontFamily="sans-serif-light"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>