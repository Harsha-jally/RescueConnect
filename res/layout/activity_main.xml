<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  RescueConnect · activity_main.xml  (Role Picker / Splash)      ║
  ║  Dark neon-pulse theme                                           ║
  ╚══════════════════════════════════════════════════════════════════╝
  DRAWABLES needed:
    • bg_role_btn_donate  — GradientDrawable startColor=#F59E0B endColor=#D97706 cornerRadius=20dp
    • bg_role_btn_blood   — GradientDrawable startColor=#E53935 endColor=#B71C1C cornerRadius=20dp
-->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        tools:context=".MainActivity">

        <!-- ── Decorative glow circle (top-left) ── -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/bg_glow_circle_red"
            android:alpha="0.18"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:translationX="-80dp"
            android:translationY="-80dp"/>

        <!-- ── Decorative glow circle (bottom-right) ── -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_glow_circle_cyan"
            android:alpha="0.14"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:translationX="60dp"
            android:translationY="60dp"/>

        <!-- ── App logo icon ── -->
        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_shield_logo"
            android:contentDescription="RescueConnect logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/appName"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="12dp"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintVertical_bias="0.12"/>

        <!-- ── App name ── -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RescueConnect"
            android:textColor="#F1F5F9"
            android:textSize="32sp"
            android:letterSpacing="0.05"
            android:fontFamily="@font/poppins_bold"
            app:layout_constraintTop_toBottomOf="@id/logoIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tagline"/>

        <!-- ── Tagline ── -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help is always a tap away"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:letterSpacing="0.03"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/appName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/roleCard"/>

        <!-- ══════════════════════════════════
             ROLE SELECTION CARD
        ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/roleCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#111827"
            app:cardCornerRadius="28dp"
            app:cardElevation="24dp"
            app:layout_constraintTop_toBottomOf="@id/tagline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/communityCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I am a…"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="20dp"/>

                <!-- USER button -->
                <Button
                    android:id="@+id/user"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_role_btn_user"
                    android:onClick="userImplementation"
                    android:text="🆘  User in Need"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="12dp"
                    android:stateListAnimator="@null"/>

                <!-- VOLUNTEER button -->
                <Button
                    android:id="@+id/volunteer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_role_btn_vol"
                    android:onClick="volunteerImplementation"
                    android:text="🙌  Volunteer Helper"
                    android:textColor="#001620"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="12dp"
                    android:stateListAnimator="@null"/>

                <!-- ADMIN button -->
                <Button
                    android:id="@+id/admin"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_role_btn_admin"
                    android:onClick="adminImplementation"
                    android:text="🛡  Administrator"
                    android:textColor="#001A14"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.02"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════
             COMMUNITY CARD  (Donations + Blood)
        ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/communityCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#0D0D0D"
            app:cardCornerRadius="28dp"
            app:cardElevation="20dp"
            app:layout_constraintTop_toBottomOf="@id/roleCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/footerText">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Community Support"
                    android:textColor="#F59E0B"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="14dp"/>

                <!-- DONATIONS button -->
                <Button
                    android:id="@+id/btnDonations"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_role_btn_donate"
                    android:onClick="donationsImplementation"
                    android:text="💰  Funds &amp; Donations"
                    android:textColor="#1A0A00"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="12dp"
                    android:stateListAnimator="@null"/>

                <!-- BLOOD DONATION button  ← NEW -->
                <Button
                    android:id="@+id/btnBloodDonation"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_role_btn_blood"
                    android:onClick="bloodDonationImplementation"
                    android:text="🩸  Blood Donation"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.02"
                    android:stateListAnimator="@null"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donate blood · Find donors · Locate blood banks"
                    android:textColor="#6B2121"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="center_horizontal"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Footer ── -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure · Fast · Life-saving"
            android:textColor="#2D3748"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/communityCard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>