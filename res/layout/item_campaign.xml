<?xml version="1.0" encoding="utf-8"?>
<!--
  RescueConnect · item_campaign.xml
  Single campaign card shown in the Donate screen
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#111827"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🏥"
                android:textSize="28sp"
                android:gravity="center"
                android:background="#1E293B"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textColor="#F1F5F9"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tvDisease"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disease"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

            <!-- Verified badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Verified"
                android:textColor="#4ADE80"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_medium"
                android:background="#0D2B1C"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- Amount labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Raised"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvRaisedAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#4ADE80"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#F1F5F9"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressDonation"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:progressTint="#4ADE80"
            android:progressBackgroundTint="#1E293B"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvPercent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0% funded"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="end"
            android:layout_marginBottom="16dp"/>

        <!-- Donate button -->
        <Button
            android:id="@+id/btnDonateCampaign"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_role_btn_donate"
            android:text="💛  Donate Now via UPI"
            android:textColor="#1A0A00"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>