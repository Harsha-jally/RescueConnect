<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml — RescueConnect
    ───────────────────────────────────────────────────────────────────────────
    Design token summary:
      Background ........... #080C17
      Card surface ......... #0C1525   (all feature & action cards)
      Volunteer card ....... #061C10   (green-tinted, stays unique)
      Card corner radius ... 16 dp
      Card elevation ....... 10 dp     (all cards)
      Horizontal margin .... 20 dp
      Button height ........ 48 dp     (all action buttons inside cards)
      SOS button ........... 152 dp perfect circle (bg_sos_button_circle = oval shape)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080C17"
    tools:context=".HomeActivity">

    <!-- ── Top bar ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/greetBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay Safe"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="RescueConnect"
                android:textColor="#F1F5F9"
                android:textSize="22sp"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/settingsBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Safety Timer Settings"
            android:onClick="settingsImplementation"
            android:src="@drawable/ic_settings"
            android:tint="#94A3B8"
            android:scaleType="centerInside"
            android:padding="10dp"/>

    </LinearLayout>

    <!-- ── Pulse rings ───────────────────────────────────────────────────── -->
    <View android:id="@+id/pulseRing3"
        android:layout_width="300dp" android:layout_height="300dp"
        android:background="@drawable/bg_pulse_ring" android:alpha="0.06"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <View android:id="@+id/pulseRing2"
        android:layout_width="230dp" android:layout_height="230dp"
        android:background="@drawable/bg_pulse_ring" android:alpha="0.10"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <View android:id="@+id/pulseRing1"
        android:layout_width="170dp" android:layout_height="170dp"
        android:background="@drawable/bg_pulse_ring" android:alpha="0.16"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- ── SOS Button ────────────────────────────────────────────────────── -->
    <!--
        Width == Height (152dp x 152dp) + bg_sos_button_circle uses android:shape="oval"
        which draws a perfect circle when the view is square. No border-radius tricks needed.
    -->
    <Button
        android:id="@+id/help"
        android:layout_width="152dp"
        android:layout_height="152dp"
        android:background="@drawable/bg_sos_button_circle"
        android:onClick="helpImplementation"
        android:text="SOS"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:fontFamily="@font/poppins_extrabold"
        android:letterSpacing="0.06"
        android:stateListAnimator="@null"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- Sub label anchored below SOS button -->
    <TextView
        android:id="@+id/sosSubLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Press in case of emergency"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/help"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Volunteer Coming Banner                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/volunteerComingCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="#061C10"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/sosSubLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">

            <!-- LIVE badge row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_green_dot"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1A4731"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="● LIVE"
                    android:textColor="#4ADE80"
                    android:textSize="10sp"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Volunteer Coming"
                    android:textColor="#4ADE80"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"/>

            </LinearLayout>

            <TextView
                android:id="@+id/volunteerComingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="🦸 A volunteer is on the way!"
                android:textColor="#F0FDF4"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Help is coming — stay calm, stay strong 💪"
                android:textColor="#86EFAC"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>

            <Button
                android:id="@+id/trackLiveBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#16A34A"
                android:text="📍  Track Live Location"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:stateListAnimator="@null"
                android:elevation="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Monitor Me Card                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/monitorMeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#0C1525"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/nearbyHospitalsCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ── INACTIVE STATE ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/monitorInactiveLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👁️  Monitor Me"
                        android:textColor="#F1F5F9"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"/>

                    <TextView
                        android:id="@+id/monitorIntervalBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#0D2240"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="5 min check-ins"
                        android:textColor="#60A5FA"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Regular safety check-ins. No response = auto SOS to contacts &amp; volunteers."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/startMonitorBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#1D4ED8"
                    android:onClick="monitorMeImplementation"
                    android:text="▶  Start Monitoring"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:stateListAnimator="@null"
                    android:elevation="4dp"/>

            </LinearLayout>

            <!-- ── ACTIVE STATE ───────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/monitorActiveLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/monitorPulseDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_pulse_ring"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/monitorStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Monitoring Active"
                        android:textColor="#4ADE80"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#1A4731"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="● LIVE"
                        android:textColor="#4ADE80"
                        android:textSize="10sp"
                        android:letterSpacing="0.10"
                        android:textAllCaps="true"
                        android:fontFamily="@font/poppins_bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/monitorNextCheckText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Next check-in in 5 min"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/stopMonitorBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#166534"
                    android:onClick="reachedDestinationImplementation"
                    android:text="🏁  I've Reached My Destination"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:stateListAnimator="@null"
                    android:elevation="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Nearby Hospitals                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/nearbyHospitalsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#0C1525"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/addContactCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/nearbyHospitalsBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@null"
            android:onClick="showNearbyHospitals"
            android:text="🏥  Show Nearby Hospitals"
            android:textColor="#34D399"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"/>

    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Add Emergency Contact                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/addContactCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#0C1525"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/addEmergencyContact"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@null"
            android:onClick="addEmergencyContactImplementation"
            android:text="👥  Add Emergency Contact"
            android:textColor="#38BDF8"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            android:stateListAnimator="@null"/>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>